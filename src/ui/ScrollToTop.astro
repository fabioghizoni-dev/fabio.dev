---
import { Icon } from "astro-icon/components";
import cn from "../utils/cn";

const finalClass =
  cn(`fixed opacity-0 pointer-events-none w-12 h-12 bg-gradient-to-br from-purple-default to-cyan-500 text-white right-4 
    bottom-4 rounded-full p-1 cursor-pointer hover:from-cyan-500 hover:to-purple-default hover:text-gray-default 
      hover:contrast-125 transition-all ease-in-out duration-500`);
---

<Icon
  id="arrow-up"
  role="button"
  type="button"
  name="ep:arrow-up-bold"
  title="Scroll to top of page"
  class={finalClass}
/>

<script src="../scripts/ScrollToTop.js"></script>
