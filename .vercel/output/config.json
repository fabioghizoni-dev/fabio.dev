{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/_actions(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/500/?$",
			"dest": "_render"
		},
		{
			"src": "^/components/?$",
			"dest": "_render"
		},
		{
			"src": "^/curriculum/?$",
			"dest": "_render"
		},
		{
			"src": "^/email/?$",
			"dest": "_render"
		},
		{
			"src": "^/gradients/?$",
			"dest": "_render"
		},
		{
			"src": "^/qr/info/?$",
			"dest": "_render"
		},
		{
			"src": "^/qr/?$",
			"dest": "_render"
		},
		{
			"src": "^/routes/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}