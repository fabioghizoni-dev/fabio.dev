---
import { Icon } from "astro-icon/components";

interface Props {
  class?: string;
}

const { class: className } = Astro.props as Props;
---

<div class={`${className} flex text-nowrap justify-center items-center gap-4`}>
  <div
    class="flex bg-purple-blue justify-center items-center gap-1 px-4 py-2 rounded-full"
  >
    <Icon
      name="material-symbols:star-rounded"
      class="w-6 h-6 text-yellow-500 brightness-200 animate-pulse"
    />
    <span class="text-lg text-white font-cascadia-code mt-0.5"
      >Full-Stack Developer</span
    >
  </div>
  <a
    role="link"
    href="/cv-fabio.pdf"
    download="cv-fabio.pdf"
    aria-label="Download CV"
    class="bg-purple-blue text-white text-xl font-cascadia-code font-bold animate-pulse-border rounded-full px-4 py-2
      cursor-pointer"
  >
    Download CV
  </a>
</div>
