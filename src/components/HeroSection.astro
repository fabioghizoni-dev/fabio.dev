---
import AsciiArt from "../ui/AsciiArts.astro";
import CircularLogo from "../ui/CircularLogo.astro";
import HeroBadge from "../ui/HeroBadge.astro";
---

<section
  id="hero"
  class="flex flex-col lg:flex-row w-full min-h-screen justify-center items-center gap-10 lg:gap-20 overflow-hidden p-4 md:p-0"
>
  <div class="relative flex flex-col justify-center items-start">
    <AsciiArt />
    <HeroBadge />
  </div>
  <CircularLogo isAnimated />
</section>
