---
import { Icon } from "astro-icon/components";
import cn from "../utils/cn";
const finalClass =
  cn(`relative flex min-w-8 min-h-8 w-8 h-8 p-0.5 ml-auto justify-center items-center hover:text-purple-blue text-white
    cursor-pointer rounded-md overflow-hidden transition-all ease-in-out duration-300`);
---

<button type="button" role="button" id="btn-theme" aria-label="Button to change theme" class={finalClass}>
  <!-- Mode Dark -->
  <Icon
    id="btn-moon"
    title="Dark mode"
    aria-label="Dark mode"
    class="absolute w-11/12 h-11/12"
    name="line-md:sunny-filled-loop-to-moon-filled-loop-transition"
  />
  <!-- Mode Light -->
  <Icon
    id="btn-sun"
    title="Light mode"
    aria-label="Light mode"
    class="absolute w-11/12 h-11/12 hidden"
    name="line-md:moon-filled-to-sunny-filled-loop-transition"
  />
</button>

<script src="../scripts/SwitchTheme.js"></script>
